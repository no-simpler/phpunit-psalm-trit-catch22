{
    "require-dev": {
        "phpunit/phpunit": "^12",
        "vimeo/psalm": "^6",
        "psalm/plugin-phpunit": "^0.19"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Test\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "psalm/plugin-phpunit": true
        }
    }
}
